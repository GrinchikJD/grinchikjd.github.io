{
  "devDependencies": {
    "cross-env": "^10.1.0",
    "cssnano": "^8.0.2",
    "tailwindcss": "^3.4.19"
  },
  "scripts": {
    "build": "cross-env NODE_ENV=production npx tailwindcss --postcss -i input.css -o ../styles.css --minify",
    "watch": "cross-env NODE_ENV=development npx tailwindcss --postcss -i input.css -o ../styles.css  --watch --verbose"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
